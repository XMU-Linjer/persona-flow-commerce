MYSQL_ROOT_PASSWORD=replace_me
MYSQL_DATABASE=persona_flow_commerce
MYSQL_USER=persona_flow
MYSQL_PASSWORD=replace_me

RABBITMQ_DEFAULT_USER=persona_flow
RABBITMQ_DEFAULT_PASS=replace_me

# DeepSeek / LLM profile recommendation enhancement.
# Copy this file to .env and fill DEEPSEEK_API_KEY locally.
# Keep DEEPSEEK_ENABLED=false when you want the Python Agent to use rule-based fallback only.
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_MAX_TOKENS=1200
DEEPSEEK_TEMPERATURE=0.2

# Java backend -> Python Agent HTTP timeout. Keep this longer than DEEPSEEK_TIMEOUT_SECONDS.
PERSONA_AGENT_TIMEOUT_MS=30000
